---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPages = await getCollection('pages');
const homePage = allPages.find((p) => p.data.path === '/');

if (!homePage) {
  throw new Error('No home page found in content/pages with path: /');
}

const { Content } = await homePage.render();
const { description } = homePage.data;
---

<Layout title="Home" description={description}>
  <div class="home-wrap">
    <!-- Hero -->
    <section class="hero container">
      <h1>
        Welcome to <em class="pink">Agentic</em><br />
        Business Schooled, for those<br />
        who'd rather learn how to<br />
        <em class="pink italic">ship an agent</em><br />
        than read another textbook.
      </h1>

      <div class="neon-sign-frame">
        <img src="/images/neon-sign.svg" alt="Agentic Schooled neon sign" width="480" height="200" />
      </div>

      <p class="hero-desc">
        Plain-spoken lessons on what AI agents actually are, what they're good for,
        and the boring work of making one earn its keep. When you're ready, build
        your first agent and see what the shift to agentic business really feels like.
      </p>

      <div class="hero-cta">
        <a href="/quick-start" class="btn-primary">Build your first AI Agent →</a>
        <a href="/curriculum" class="btn-ghost">Why agentic AI</a>
      </div>
    </section>

    <!-- Markdown-powered content sections -->
    <section class="content-sections container">
      <div class="prose home-prose">
        <Content />
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-wrap {
    padding-bottom: 6rem;
  }

  /* ── Hero (single column) ── */
  .hero {
    padding-top: 4.5rem;
    padding-bottom: 4rem;
    max-width: 760px;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: #fff;
    margin-bottom: 2.5rem;
    font-style: normal;
  }

  .hero h1 .pink {
    color: var(--pink-bright);
  }

  .hero h1 .italic {
    font-style: italic;
  }

  .neon-sign-frame {
    border: 1px solid rgba(226, 0, 122, 0.25);
    border-radius: 10px;
    background: #0d0015;
    padding: 1.5rem 1rem;
    box-shadow: 0 0 60px rgba(226, 0, 122, 0.12), inset 0 0 60px rgba(120, 0, 80, 0.08);
    overflow: hidden;
    margin: 0 0 2.5rem;
    max-width: 520px;
  }

  .neon-sign-frame img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    border: none;
    background: transparent;
  }

  .hero-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 2.25rem;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: var(--pink);
    color: #fff;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    transition: background 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 24px rgba(226, 0, 122, 0.45);
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--pink-bright);
    box-shadow: 0 0 36px rgba(226, 0, 122, 0.7);
    text-decoration: none;
  }

  .btn-ghost {
    color: var(--muted);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .btn-ghost:hover {
    color: var(--text);
    text-decoration: none;
  }

  .content-sections {
    padding-top: 1rem;
  }
</style>
