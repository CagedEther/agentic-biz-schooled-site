---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPages = await getCollection('pages');
const homePage = allPages.find((p) => p.data.path === '/');

if (!homePage) {
  throw new Error('No home page found in content/pages with path: /');
}

const { Content } = await homePage.render();
const { description } = homePage.data;
---

<Layout title="Home" description={description}>
  <div class="home-wrap">
    <!-- Hero -->
    <section class="hero container">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="dot"></span>
          NEW SCHOOLING — COHORT 04
        </div>
        <h1>
          Welcome to <em class="pink">Agentic</em><br />
          Business Schooled, the<br />
          curriculum for builders<br />
          who'd rather <em class="pink italic">ship an agent</em><br />
          than read another textbook.
        </h1>
        <p class="hero-desc">
          Plain-spoken lessons on what AI agents actually are, what they're good for,
          and the boring work of making one earn its keep. When you're ready to test
          an idea, hit Quick Start — an agent will pressure-test your business
          proposition in minutes.
        </p>
        <div class="hero-cta">
          <a href="/quick-start" class="btn-primary">Share your idea with a business idea →</a>
          <a href="/curriculum" class="btn-ghost">Browse the curriculum</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="neon-sign-frame">
          <img src="/images/neon-sign.svg" alt="Agentic Schooled neon sign" width="480" height="200" />
        </div>
        <div class="hero-status">
          <span class="status-dot"></span>
          <span class="status-label">OPEN&nbsp;&nbsp;LIVE</span>
          <span class="status-text">Class in session</span>
        </div>
      </div>
    </section>

    <!-- Markdown-powered content sections -->
    <section class="content-sections container">
      <div class="prose home-prose">
        <Content />
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-wrap {
    padding-bottom: 6rem;
  }

  /* ── Hero ── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 4rem;
    align-items: start;
    padding-top: 5rem;
    padding-bottom: 4rem;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--pink-bright);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
  }

  .hero-badge .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--pink-bright);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--pink-bright), 0 0 20px var(--pink-bright);
    flex-shrink: 0;
  }

  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.035em;
    color: #fff;
    margin-bottom: 1.75rem;
    font-style: normal;
  }

  .hero h1 .pink {
    color: var(--pink-bright);
  }

  .hero h1 .italic {
    font-style: italic;
  }

  .hero-desc {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 2.25rem;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: var(--pink);
    color: #fff;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    transition: background 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 24px rgba(226, 0, 122, 0.45);
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--pink-bright);
    box-shadow: 0 0 36px rgba(226, 0, 122, 0.7);
    text-decoration: none;
  }

  .btn-ghost {
    color: var(--muted);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .btn-ghost:hover {
    color: var(--text);
    text-decoration: none;
  }

  /* ── Hero right ── */
  .hero-right {
    padding-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .neon-sign-frame {
    border: 1px solid rgba(226, 0, 122, 0.25);
    border-radius: 10px;
    background: #0d0015;
    padding: 1.5rem 1rem;
    box-shadow: 0 0 60px rgba(226, 0, 122, 0.12), inset 0 0 60px rgba(120, 0, 80, 0.08);
    overflow: hidden;
  }

  .neon-sign-frame img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    border: none;
    background: transparent;
  }

  .hero-status {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: #00e676;
    border-radius: 50%;
    box-shadow: 0 0 8px #00e676, 0 0 16px #00e676;
    flex-shrink: 0;
  }

  .status-label {
    color: #00c853;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .status-text {
    color: var(--muted);
  }

  /* ── Content sections ── */
  .content-sections {
    padding-top: 2rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 3rem;
    }

    .hero-right {
      order: -1;
      max-width: 420px;
    }
  }
</style>
