---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const allPages = await getCollection('pages');
const navPages = allPages
  .filter((p) => !p.data.hideFromNav)
  .sort((a, b) => a.data.order - b.data.order);

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Home' ? 'Agentic Business Schooled' : `${title} — Agentic Schooled`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">
          <span class="logo-pink">Agentic</span> Business Schooled
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation">
          <span></span><span></span><span></span>
        </button>
        <nav class="site-nav" id="site-nav">
          <ul>
            {navPages.map((page) => {
              const href = page.data.path;
              const isActive = href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(href);
              return (
                <li>
                  <a href={href} class={isActive ? 'active' : ''}>{page.data.title}</a>
                </li>
              );
            })}
          </ul>
          <a href="/quick-start" class="nav-cta">Build your first AI Agent →</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <div class="footer-logo">
            <span class="logo-pink">Agentic</span> Business Schooled
          </div>
          <p class="footer-tagline">
            The unconventional curriculum for builders who'd rather ship an
            agent than read another textbook.
          </p>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Learn</div>
          <ul>
            <li><a href="/curriculum">Curriculum</a></li>
            <li><a href="/quick-start">Quick Start</a></li>
            <li><a href="/lessons">Lessons</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Stay Schooled</div>
          <p class="footer-note">New lessons drop monthly. No spam, just signal.</p>
        </div>
      </div>
      <div class="container footer-bottom">
        <p>© 2026 Agentic Business Schooled. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('site-nav');
      toggle?.addEventListener('click', () => {
        nav?.classList.toggle('open');
        toggle.classList.toggle('open');
      });
    </script>
  </body>
</html>

<style is:global>
  /* ─── Reset ─── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ─── Design tokens ─── */
  :root {
    --bg:           #07070d;
    --bg-surface:   #0d0d1a;
    --bg-card:      #0e0e18;
    --border:       #1c1c2e;
    --border-dim:   #141420;
    --pink:         #e2007a;
    --pink-bright:  #ff2d96;
    --pink-dim:     #7a003d;
    --pink-glow:    rgba(226, 0, 122, 0.4);
    --text:         #dcdce8;
    --muted:        #58586e;
    --heading:      #ffffff;
    --link:         #ff66b8;
    --code-bg:      #111120;
    --font-sans:    -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    --font-mono:    'JetBrains Mono', 'Fira Code', 'Cascadia Code', Menlo, monospace;
    --radius:       8px;
    --max-width:    960px;
    --header-height: 60px;
  }

  /* ─── Base ─── */
  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    background-color: var(--bg);
    background-image:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(120, 0, 200, 0.12) 0%, transparent 70%),
      linear-gradient(rgba(28, 28, 46, 0.35) 1px, transparent 1px),
      linear-gradient(90deg, rgba(28, 28, 46, 0.35) 1px, transparent 1px);
    background-size: 100% 100%, 60px 60px, 60px 60px;
    background-attachment: fixed;
    color: var(--text);
    font-family: var(--font-sans);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  a {
    color: var(--link);
    text-decoration: none;
    transition: color 0.15s;
  }

  a:hover {
    color: var(--pink-bright);
    text-decoration: none;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--code-bg);
    padding: 0.15em 0.45em;
    border-radius: 4px;
    color: var(--pink-bright);
    border: 1px solid var(--border);
  }

  pre {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.65;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
  }

  /* ─── Layout ─── */
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.75rem;
  }

  .site-main {
    flex: 1;
  }

  /* ─── Header ─── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    height: var(--header-height);
    background: rgba(7, 7, 13, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-dim);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 2rem;
  }

  .logo {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo:hover {
    color: #fff;
  }

  .logo-pink {
    color: var(--pink-bright);
  }

  /* ─── Nav ─── */
  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .site-nav ul {
    display: flex;
    list-style: none;
    gap: 0;
  }

  .site-nav ul a {
    display: block;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.875rem;
    transition: color 0.15s, background 0.15s;
  }

  .site-nav ul a:hover {
    color: var(--text);
  }

  .site-nav ul a.active {
    color: #fff;
  }

  /* "Launch agent" pill button */
  .nav-cta {
    display: inline-block;
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--pink);
    border-radius: 6px;
    color: var(--pink-bright) !important;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    white-space: nowrap;
    margin-left: 0.5rem;
    transition: background 0.2s, box-shadow 0.2s, color 0.2s;
  }

  .nav-cta:hover {
    background: rgba(226, 0, 122, 0.1);
    box-shadow: 0 0 14px rgba(226, 0, 122, 0.3);
    color: #fff !important;
  }

  /* Mobile hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    width: 34px;
    height: 34px;
    flex-shrink: 0;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── Footer ─── */
  .site-footer {
    border-top: 1px solid var(--border-dim);
    padding-top: 3.5rem;
    padding-bottom: 2rem;
    margin-top: 4rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 280px;
  }

  .footer-col-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.9rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col ul a {
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .footer-col ul a:hover {
    color: var(--text);
  }

  .footer-note {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .footer-bottom {
    border-top: 1px solid var(--border-dim);
    padding-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  /* ─── Prose ─── */
  .prose {
    max-width: 100%;
  }

  .prose h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--heading);
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-shadow: 0 0 40px rgba(226, 0, 122, 0.2);
  }

  .prose h2 {
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    font-weight: 800;
    color: var(--heading);
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .prose h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--heading);
    letter-spacing: -0.01em;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
  }

  .prose p {
    color: var(--text);
    margin-bottom: 1.1rem;
    font-size: 0.95rem;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    padding-left: 0;
  }

  .prose ul li,
  .prose ol li {
    font-size: 0.95rem;
    color: var(--text);
    padding-left: 1.1rem;
    position: relative;
  }

  .prose ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--pink);
    font-weight: 700;
  }

  .prose ol {
    counter-reset: ol;
  }

  .prose ol li {
    counter-increment: ol;
  }

  .prose ol li::before {
    content: counter(ol, decimal-leading-zero);
    position: absolute;
    left: 0;
    color: var(--pink-bright);
    font-size: 0.78rem;
    font-weight: 700;
    top: 0.18em;
  }

  .prose strong {
    color: var(--heading);
    font-weight: 700;
  }

  .prose em {
    color: var(--pink-bright);
    font-style: italic;
  }

  .prose a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255, 102, 184, 0.35);
    transition: color 0.15s, text-decoration-color 0.15s;
  }

  .prose a:hover {
    color: var(--pink-bright);
    text-decoration-color: var(--pink-bright);
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* Blockquote — styled as a pink-bordered card (used for Quick Start callout) */
  .prose blockquote {
    border: 1px solid rgba(226, 0, 122, 0.25);
    border-left: 3px solid var(--pink);
    background: var(--bg-card);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.75rem 2rem;
    margin: 2rem 0;
    font-style: normal;
    box-shadow: 0 0 40px rgba(226, 0, 122, 0.06), inset 0 0 40px rgba(100, 0, 60, 0.04);
  }

  .prose blockquote p {
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .prose blockquote p:last-child {
    margin-bottom: 0;
  }

  .prose blockquote strong {
    font-size: 1.05rem;
    color: #fff;
  }

  .prose blockquote a {
    color: var(--pink-bright);
    font-weight: 600;
  }

  /* Tables */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose th {
    text-align: left;
    padding: 0.6rem 1rem;
    background: var(--bg-surface);
    color: var(--muted);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
  }

  .prose td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border-dim);
    color: var(--text);
    font-size: 0.9rem;
  }

  .prose tr:last-child td {
    border-bottom: none;
  }

  /* Images in prose */
  .prose img {
    display: block;
    margin: 2.5rem auto;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    box-shadow: 0 0 40px rgba(226, 0, 122, 0.08);
  }

  /* ─── Home-page specific prose overrides ─── */
  .home-prose h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-top: 4rem;
    position: relative;
  }

  /* Section eyebrow label via ::before on first h2 */
  .home-prose .section-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pink-bright);
    margin-bottom: 0.5rem;
  }

  /* Lesson list — custom 2-col grid */
  .home-prose ul {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 1.5rem 0 2rem;
    padding-left: 0;
    list-style: none;
  }

  .home-prose ul li {
    padding: 1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.875rem;
    color: var(--muted);
    transition: border-color 0.2s, box-shadow 0.2s;
    padding-left: 1.25rem;
  }

  .home-prose ul li::before {
    display: none;
  }

  .home-prose ul li:hover {
    border-color: rgba(226, 0, 122, 0.3);
    box-shadow: 0 0 20px rgba(226, 0, 122, 0.06);
    color: var(--text);
  }

  .home-prose ul li strong {
    display: block;
    color: #fff;
    font-size: 0.875rem;
    margin-bottom: 0.2rem;
  }

  /* Closing line after final hr */
  .home-prose hr + p {
    text-align: center;
    max-width: 640px;
    margin: 2.5rem auto 0;
    font-size: 1rem;
    color: var(--muted);
  }

  /* ─── Responsive ─── */
  @media (max-width: 720px) {
    .nav-toggle {
      display: flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: var(--header-height);
      left: 0;
      right: 0;
      background: rgba(7, 7, 13, 0.97);
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 1.75rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .site-nav.open {
      display: flex;
    }

    .site-nav ul {
      flex-direction: column;
      gap: 0;
      width: 100%;
    }

    .site-nav ul a {
      padding: 0.6rem 0;
      font-size: 1rem;
      width: 100%;
    }

    .nav-cta {
      margin-left: 0;
      margin-top: 0.5rem;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .home-prose ul {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 1.25rem;
    }
  }
</style>
